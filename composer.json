{
    "name": "vocweb/laravel-log-compress",
    "description": "Auto-compress daily rotated Laravel log files with optional password protection",
    "keywords": ["laravel", "log", "compress", "archive", "tar"],
    "license": "MIT",
    "authors": [
        {
            "name": "vocweb"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/process": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "vocweb\\LaravelLogCompress\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "vocweb\\LaravelLogCompress\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "vocweb\\LaravelLogCompress\\LogCompressServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
